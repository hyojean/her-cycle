# Supabase (프로젝트 설정 → API)
# https://supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# RLS 사용 시: Authentication → Providers → Anonymous 로그인 활성화 권장
# 소셜 로그인 사용 시:
# - Authentication → Providers에서 Google/Kakao 활성화
# - Authentication → URL Configuration에 배포 URL과 로컬 개발 URL 등록
#   예: http://localhost:5173, https://your-domain.example

# AI 채팅 (Supabase Edge Function `chat` — 프론트 .env에 Gemini 키 넣지 마세요)
# 1) Google AI Studio API 키: https://aistudio.google.com/apikey
# 2) Supabase 대시보드 → Edge Functions → Secrets:
#    GEMINI_API_KEY=...
#    (선택) GEMINI_MODEL=gemini-2.5-flash
# 3) CLI 예:
#    npx supabase secrets set GEMINI_API_KEY=YOUR_KEY --project-ref mkojqgdxqioalcndmtwy
#    npx supabase functions deploy chat --project-ref mkojqgdxqioalcndmtwy --use-api
